build/
# JDS-PRJ-SFW-003 ships its distro build system in a 'build/' folder — that is
# source, not output. Re-include it (CA-2026-012).
!projects/software/JDS-PRJ-SFW-003_pocket-linux/build/
*.log
*.local

# Python
__pycache__/
*.pyc
.venv/

# Environment
.env
.env.local

# Generated outputs — JDS-PRO-005 §6: Git is the controlled copy, exports are uncontrolled
*.pdf
*.xlsx

# safe-to-delete/ is for temporary review files — never commit generated outputs
safe-to-delete/

# Proprietary device firmware (Gobi WWAN etc.) — licensed per-machine, never redistributable
*.mbn
